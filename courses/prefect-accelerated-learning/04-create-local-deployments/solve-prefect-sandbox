#!/bin/bash
set -euxo pipefail

cd /root/pal

cat <<'EOF' > local_deploy.py
from pathlib import Path

from prefect import flow


@flow(log_prints=True)
def greet_flow(name: str = "PAL learner"):
    print(f"Hello, {name}!")
    print(f"Running from {Path(__file__).resolve()}")


if __name__ == "__main__":
    greet_flow(name="PAL learner")
EOF

cat <<'EOF' > deploy_local.py
from pathlib import Path

from local_deploy import greet_flow


if __name__ == "__main__":
    greet_flow.from_source(
        source=str(Path(__file__).parent),
        entrypoint="local_deploy.py:greet_flow",
    ).deploy(
        name="pal-local-greeting",
        work_pool_name="pal-process-pool",
    )
EOF
