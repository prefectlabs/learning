#!/bin/bash
set -euxo pipefail

export PATH="/root/.local/bin:$PATH"
cd /root/quacksync

if ! grep -q 'write_duck\.map' quacksync/flow.py; then
  fail-message "quacksync/flow.py should call write_duck.map(...) instead of the serial write loop."
  exit 1
fi

if ! grep -q 'concurrency(' quacksync/tasks.py && ! grep -q 'concurrency(' quacksync/flow.py; then
  fail-message "Wrap the database call in a concurrency(\"db-writes\", ...) context manager."
  exit 1
fi

if ! grep -q '"db-writes"' quacksync/tasks.py quacksync/flow.py; then
  fail-message "The concurrency limit should be named 'db-writes' to match the rest of the track."
  exit 1
fi

if ! uv run prefect gcl inspect db-writes >/dev/null 2>&1; then
  fail-message "The global concurrency limit 'db-writes' doesn't exist. Create it with 'uv run prefect gcl create db-writes --limit 5'."
  exit 1
fi

if [ ! -f quacksync.db ]; then
  fail-message "Run the flow after adding the concurrency limit."
  exit 1
fi

count=$(sqlite3 quacksync.db 'SELECT COUNT(*) FROM ducks;' 2>/dev/null || echo 0)
if [ "$count" -lt 460 ]; then
  fail-message "Expected roughly 475 rows once writes are protected, but found $count. Re-run the flow after fixing write_duck."
  exit 1
fi
