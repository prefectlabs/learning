#!/bin/bash
# Build published assets for the Scaling Workflows with Prefect track.
#
# Produces:
#   - assets/quacksync-starter.tar.gz           : the starter project archive
#   - track_scripts/setup-prefect-sandbox       : sandbox bootstrap script
#     with the starter tarball embedded as base64 so the VM can unpack it
#     without any external asset fetching.
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
cd "$HERE"

mkdir -p assets track_scripts

TARBALL="assets/quacksync-starter.tar.gz"

tar \
  --exclude='.venv' \
  --exclude='__pycache__' \
  --exclude='*.pyc' \
  --exclude='quacksync.db' \
  -czf "$TARBALL" \
  -C asset-sources quacksync

B64="$(base64 < "$TARBALL" | tr -d '\n' | fold -w 76)"

cat > track_scripts/setup-prefect-sandbox <<'PART1'
#!/bin/bash
# Generated by build-assets. Do not edit directly.
# Edit asset-sources/quacksync/ or build-assets instead.
set -euxo pipefail

until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
  sleep 1
done

apt-get update
apt-get install -y curl ca-certificates

# uv gives us a fast, single-tool Python install and venv workflow.
curl -LsSf https://astral.sh/uv/install.sh | sh
export PATH="/root/.local/bin:$PATH"
echo 'export PATH="/root/.local/bin:$PATH"' >> /root/.bashrc

mkdir -p /root/quacksync
cd /root

# The quacksync starter project is embedded below as a base64 tarball so the
# sandbox needs no outbound access to the Instruqt asset CDN.
base64 -d > /tmp/quacksync-starter.tar.gz <<'B64_END'
PART1

printf '%s\n' "$B64" >> track_scripts/setup-prefect-sandbox

cat >> track_scripts/setup-prefect-sandbox <<'PART2'
B64_END
tar -xzf /tmp/quacksync-starter.tar.gz -C /root
rm -f /tmp/quacksync-starter.tar.gz

cd /root/quacksync
uv sync

# Pre-cache the Prefect CLI so the first `prefect` call is instant.
uv run prefect version

# Write a convenience start-stack script the learner will use from lab 1.
cat > /root/quacksync/start-stack.sh <<'STACK'
#!/bin/bash
# Start the mock server and the Prefect server as background processes.
set -euo pipefail
cd "$(dirname "$0")"

pkill -f "mock_server.py" >/dev/null 2>&1 || true
pkill -f "prefect server start" >/dev/null 2>&1 || true

nohup uv run python mock_server.py > /tmp/mock_server.log 2>&1 &
nohup uv run prefect server start > /tmp/prefect_server.log 2>&1 &

# Wait for both to come up.
for _ in $(seq 1 40); do
  if curl -sf http://127.0.0.1:8000/ducks/1 >/dev/null \
     && curl -sf http://127.0.0.1:4200/api/health >/dev/null; then
    echo "Stack is up."
    exit 0
  fi
  sleep 1
done

echo "Stack did not come up in time. Check /tmp/mock_server.log and /tmp/prefect_server.log." >&2
exit 1
STACK
chmod +x /root/quacksync/start-stack.sh
PART2

chmod +x track_scripts/setup-prefect-sandbox

echo "Built:"
echo "  $TARBALL"
echo "  track_scripts/setup-prefect-sandbox"
