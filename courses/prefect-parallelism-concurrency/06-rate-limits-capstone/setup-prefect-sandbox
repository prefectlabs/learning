#!/bin/bash
set -euxo pipefail

export PATH="/root/.local/bin:$PATH"
cd /root/quacksync

cp quacksync/snapshots/flow_module_6_start.py quacksync/flow.py

cat > quacksync/tasks.py <<'EOF'
from __future__ import annotations

import httpx
from prefect import task
from prefect.concurrency.sync import concurrency

from .database import pool
from .scoring import ScorerConfig, score_record

CATALOG_URL = "http://127.0.0.1:8000/ducks/{duck_id}"
ENRICH_URL = "http://127.0.0.1:8000/enrichment/{duck_id}"


@task
def fetch_duck(duck_id: int) -> dict:
    response = httpx.get(CATALOG_URL.format(duck_id=duck_id), timeout=5.0)
    response.raise_for_status()
    return response.json()


@task
def enrich_duck(duck: dict) -> dict:
    response = httpx.get(ENRICH_URL.format(duck_id=duck["id"]), timeout=5.0)
    response.raise_for_status()
    enrichment = response.json()
    return {**duck, **{k: v for k, v in enrichment.items() if k != "id"}}


@task
def score_duck(duck: dict) -> dict:
    duck["score"] = score_record(duck, ScorerConfig())
    return duck


@task
def write_duck(duck: dict) -> int:
    with concurrency("db-writes", occupy=1):
        pool.upsert_duck(duck)
    return duck["id"]
EOF

rm -f quacksync.db

./start-stack.sh

# Make sure the db-writes limit from module 5 carries into module 6.
uv run prefect gcl create db-writes --limit 5 2>/dev/null || true

# Clean up any previous enrichment limits so learners create them fresh.
uv run prefect gcl delete enrichment-api-rps --yes >/dev/null 2>&1 || true
uv run prefect gcl delete enrichment-api-conns --yes >/dev/null 2>&1 || true
