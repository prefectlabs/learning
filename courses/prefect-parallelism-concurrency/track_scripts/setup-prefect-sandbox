#!/bin/bash
# Start the mock server and the Prefect server as background processes.
set -euo pipefail
cd "$(dirname "$0")"

pkill -f "mock_server.py" >/dev/null 2>&1 || true
pkill -f "prefect server start" >/dev/null 2>&1 || true

nohup uv run python mock_server.py > /tmp/mock_server.log 2>&1 &
nohup uv run prefect server start > /tmp/prefect_server.log 2>&1 &

# Wait for both to come up.
for _ in $(seq 1 40); do
  if curl -sf http://127.0.0.1:8000/ducks/1 >/dev/null \
     && curl -sf http://127.0.0.1:4200/api/health >/dev/null; then
    echo "Stack is up."
    exit 0
  fi
  sleep 1
done

echo "Stack did not come up in time. Check /tmp/mock_server.log and /tmp/prefect_server.log." >&2
exit 1
STACK
